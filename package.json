{
  "name": "gnostyk-biblioteka",
  "private": true,
  "version": "1.7.42",
  "description": "Testy zabezpieczające Biblioteki Gnozy",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:pwa": "node tools/check-pwa.js",
    "test:performance": "node tools/check-performance.js",
    "test:release-assets": "node tools/check-release-assets.js",
    "test:browser": "node tests/browser-smoke.js",
    "test:translation": "node tools/check-pistis-translation.js",
    "test:release": "python tools/release.py check",
    "package:release": "python tools/release.py package"
  },
  "devDependencies": {
    "playwright": "1.61.1"
  },
  "engines": {
    "node": ">=18"
  }
}
